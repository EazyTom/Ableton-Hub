{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ableton-hub.local/schemas/similarity_tree_result.json",
  "title": "SimilarityTreeResult",
  "description": "Worker-to-UI payload for the Similarity Cluster Tree view (logical contract).",
  "type": "object",
  "required": ["version", "root_nodes", "projects", "warnings"],
  "properties": {
    "version": {
      "type": "string",
      "description": "Schema version for forward compatibility.",
      "pattern": "^1\\."
    },
    "computed_at": {
      "type": "string",
      "format": "date-time"
    },
    "parameters": {
      "type": "object",
      "additionalProperties": true
    },
    "root_nodes": {
      "type": "array",
      "items": { "$ref": "#/$defs/tree_node" }
    },
    "projects": {
      "type": "object",
      "description": "Map of project_id (string key) to display metadata for leaves.",
      "additionalProperties": {
        "type": "object",
        "required": ["display_name"],
        "properties": {
          "display_name": { "type": "string" },
          "tempo": { "type": ["number", "null"] }
        },
        "additionalProperties": true
      }
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "$defs": {
    "tree_node": {
      "type": "object",
      "required": ["kind", "label"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["group", "project"]
        },
        "node_id": { "type": "string" },
        "label": { "type": "string" },
        "breakdown_lines": {
          "type": "array",
          "description": "Optional multi-line cluster summary (group nodes).",
          "items": { "type": "string" }
        },
        "project_id": {
          "type": "integer",
          "description": "Set when kind is project."
        },
        "children": {
          "type": "array",
          "items": { "$ref": "#/$defs/tree_node" }
        }
      },
      "additionalProperties": false
    }
  }
}
